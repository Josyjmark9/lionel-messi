rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: config
    // Document ID: main
    // Fields:
    //   - hero: object (name1, name2, tag, bgImage, profileImage)
    //   - quote: object (text, attr)
    //   - footer: object (bgImage)
    //   - trophies: list of objects
    //   - timeline: list of objects
    //   - stats: list of objects
    //   - achievements: list of objects
    //   - seo: object
    //
    // Document ID: media
    // Fields:
    //   - photoStrip: list of objects
    //   - socialPhotos: list of strings
    //   - partners: list of objects
    //   - signature: string (base64)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "josiahjohnmark9@gmail.com" && request.auth.token.email_verified == true);
    }

    match /config/{document} {
      // Anyone can read the site configuration
      allow read: if true;
      
      // Only the admin can update the site configuration
      allow write: if isAdmin();
    }
  }
}
